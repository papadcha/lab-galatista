{
  "name": "daigma-lims",
  "version": "2.4.1",
  "type": "module",
  "description": "ΔAiγμα LiMS — Σύστημα Ποιοτικού Ελέγχου",
  "main": "main.js",
  "scripts": {
    "start": "npx electron .",
    "test:crash-recovery": "electron scripts/test-crash-recovery.js",
    "prebuild:backend": "node scripts/check-spec-datas.js",
    "build:backend": "pyinstaller --clean --noconfirm lab-backend.spec",
    "prebuild:installer": "node scripts/check-builder-files.js",
    "build:installer": "electron-builder --win --x64",
    "dist": "npm run build:backend && npm run build:installer"
  },
  "keywords": [],
  "author": "Λατομεία Γαλάτιστας ΑΕ",
  "license": "ISC",
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "playwright-core": "^1.61.1"
  },
  "dependencies": {
    "nodemailer": "^9.0.3"
  },
  "allowScripts": {
    "electron@43.0.0": true,
    "electron-winstaller@5.4.0": true
  },
  "build": {
    "appId": "com.daigma.lims",
    "productName": "ΔAiγμα LiMS",
    "copyright": "© 2026 Λατομεία Γαλάτιστας ΑΕ",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main.js",
      "preload.cjs",
      "standards.json",
      "VERSIONS.md",
      "github-token.json",
      "modules/**/*",
      "src/**/*",
      "fonts/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/playwright-core/**/*",
      "!dist/**/*",
      "!dist-installer/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/lab-backend",
        "to": "lab-backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "rclone",
        "to": "rclone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeaderIcon": "src/assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ΔAiγμα LiMS",
      "license": "LICENSE.txt",
      "artifactName": "Setup.${version}.exe"
    }
  }
}
